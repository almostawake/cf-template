{
  "name": "cf-template",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "astro build && wrangler pages deploy dist",
    "deploy:staging": "astro build && wrangler pages deploy dist --env staging",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:staging": "wrangler d1 migrations apply DB --env staging --remote",
    "db:migrate:production": "wrangler d1 migrations apply DB --env production --remote",
    "types": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check --write .",
    "check:ci": "biome check ."
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.5.1",
    "@astrojs/svelte": "^7.0.8",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.7.10",
    "drizzle-orm": "^0.40.1",
    "svelte": "^5.28.2",
    "tailwindcss": "^3.4.17",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/vitest-pool-workers": "^0.8.1",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "wrangler": "^4.14.0"
  }
}
